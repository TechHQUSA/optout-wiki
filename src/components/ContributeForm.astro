---
// src/components/ContributeForm.astro
// The draft-submission form for /contribute. Fields map 1:1 to the JSON
// payload expected by POST /api/contribute (functions/api/contribute.js,
// Task 14): title, category, level, body, sources[], anonymous, contributor,
// website (honeypot), altcha. Styling is a fresh implementation (not a
// verbatim port) — contribute.dc.html's form used runtime-only constructs
// (sc-for category/level "pill" buttons, onClick state, onSubmit handler)
// that have no static-HTML equivalent, so category/level are plain <select>s
// and sources is a single comma-separated <input> per the task brief, which
// also matches the API's `sources: string[]` shape more directly than the
// prototype's one-URL-per-line textarea.
//
// ALTCHA: the widget (`<altcha-widget>`, registered by `import 'altcha'` in
// the client <script> below) fetches a challenge from `challengeurl` and,
// once solved, injects its own hidden `<input name="altcha">` into this
// form — that's what `fd.get('altcha')` below reads (ALTCHA's documented
// default hidden-field name; see node_modules/altcha/README.md#configuration).
//
// Honeypot: `name="website"` is visually hidden (off-screen position, not
// display:none/visibility:hidden, so basic bots that skip hidden fields
// still fill it) and excluded from the tab order / a11y tree. Server-side
// (functions/_shared/security.js `isHoneypotTripped`) rejects any submission
// where it's non-empty — see functions/api/contribute.js step 1.
const categories = ['Cars', 'Phones', 'Business', 'Browsers', 'OS'];
---
<form id="contribute-form" class="contribute-form">
  <div class="form-head">Draft a submission</div>

  <!-- Guide/Software toggle. The radios are direct children of the form so
       the pure-CSS `:checked ~` sibling rules below can swap the two
       fieldsets with no JS (the client script only syncs `disabled` and the
       ?type=software preselect). -->
  <input type="radio" id="ctype-guide" name="ctype" value="guide" class="type-radio" checked />
  <input type="radio" id="ctype-software" name="ctype" value="software" class="type-radio" />
  <div class="type-toggle">
    <label for="ctype-guide">Opt-out guide</label>
    <label for="ctype-software">Software / service</label>
  </div>

  <fieldset class="fields-guide">
  <label class="field-label" for="cf-title">Guide title</label>
  <input
    id="cf-title"
    name="title"
    required
    placeholder={'e.g. Opt out of Comcast’s "Use my data for ads"'}
    class="field-input"
  />

  <div class="field-row">
    <div>
      <label class="field-label" for="cf-category">Category</label>
      <select id="cf-category" name="category" class="field-input">
        {categories.map((c) => <option value={c}>{c}</option>)}
      </select>
    </div>
    <div>
      <label class="field-label" for="cf-level">Difficulty</label>
      <select id="cf-level" name="level" class="field-input">
        <option value="LOW">LOW</option>
        <option value="MED" selected>MED</option>
        <option value="HIGH">HIGH</option>
      </select>
    </div>
  </div>

  <label class="field-label" for="cf-body">The steps <span class="field-hint">— Markdown welcome</span></label>
  <textarea
    id="cf-body"
    name="body"
    required
    rows="8"
    placeholder={'1. Go to ...\n2. Toggle off ...\n3. Call ... and ask for ...'}
    class="field-input field-mono"
  ></textarea>

  <label class="field-label" for="cf-sources">Sources <span class="field-hint">— comma-separated URLs</span></label>
  <input
    id="cf-sources"
    name="sources"
    placeholder="https://example.com/privacy, https://example.com/opt-out"
    class="field-input field-mono"
  />
  </fieldset>

  <!-- Software/service recommendation fields. Starts `disabled` (guide is the
       default type) so its inputs stay out of FormData and native validation;
       the client script flips `disabled` when the toggle changes. -->
  <fieldset class="fields-software" disabled>
  <label class="field-label" for="cf-sw-name">Tool name</label>
  <input id="cf-sw-name" name="sw-name" required placeholder="e.g. Mullvad VPN" class="field-input" />

  <div class="field-row">
    <div>
      <label class="field-label" for="cf-sw-category">Category</label>
      <select id="cf-sw-category" name="sw-category" class="field-input">
        <option>Browser</option>
        <option>Search</option>
        <option>Email</option>
        <option>Messaging</option>
        <option>Network</option>
        <option>DNS</option>
        <option>Passwords</option>
        <option>OS</option>
        <option>Other</option>
      </select>
    </div>
    <div>
      <label class="field-label" for="cf-sw-url">Homepage URL</label>
      <input
        id="cf-sw-url"
        name="sw-url"
        type="url"
        required
        placeholder="https://mullvad.net"
        class="field-input field-mono"
      />
    </div>
  </div>

  <label class="field-label" for="cf-sw-summary">One-line summary <span class="field-hint">— what it replaces or protects</span></label>
  <input
    id="cf-sw-summary"
    name="sw-summary"
    required
    placeholder="Anonymous, no-account VPN paid by cash or crypto."
    class="field-input"
  />

  <label class="field-label" for="cf-sw-tags">Tags <span class="field-hint">— comma-separated, e.g. vpn, no-logs</span></label>
  <input id="cf-sw-tags" name="sw-tags" placeholder="vpn, no-logs" class="field-input field-mono" />

  <label class="field-label" for="cf-sw-justification">Why recommend it? <span class="field-hint">— open source? audited? telemetry-free? Seen by moderators only</span></label>
  <textarea
    id="cf-sw-justification"
    name="sw-justification"
    rows="5"
    placeholder="Open source (GPL), independently audited in 2025, no account required..."
    class="field-input field-mono"
  ></textarea>

  <label class="field-label" for="cf-sw-sources">Evidence links <span class="field-hint">— comma-separated URLs: audit reports, license, docs</span></label>
  <input
    id="cf-sw-sources"
    name="sw-sources"
    placeholder="https://example.com/audit, https://github.com/example"
    class="field-input field-mono"
  />
  </fieldset>

  <div class="field-foot">
    <label class="checkbox-label">
      <input id="cf-anonymous" type="checkbox" name="anonymous" checked />
      Submit anonymously
    </label>
    <input
      id="cf-contributor"
      name="contributor"
      placeholder="Name (optional)"
      class="field-input field-contributor"
    />
  </div>

  <!-- honeypot: hidden from humans, left for bots that fill every field -->
  <input
    name="website"
    tabindex="-1"
    autocomplete="off"
    class="honeypot-field"
    aria-hidden="true"
  />

  <div class="altcha-row">
    <!-- workerurl points at a SAME-ORIGIN copy of ALTCHA's PoW worker
         (public/altcha-worker.js) so it loads under worker-src 'self'. The
         default 'altcha' build instead spins up a blob:/data: worker, which
         our strict CSP (no blob:/data: in script-src/worker-src) blocks — see
         the `import 'altcha/altcha.ext'` note in the client script below. -->
    <altcha-widget challengeurl="/api/altcha-challenge" workerurl="/altcha-worker.js"></altcha-widget>
  </div>

  <div class="form-submit">
    <button type="submit" class="submit-btn">
      Submit draft
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>

  <div id="contribute-result" class="result" role="status" hidden></div>
</form>

<script>
  // Use ALTCHA's EXTERNAL build (dist_external), not the default bundle. The
  // default 'altcha' inlines its PoW worker and creates it from a blob:/data:
  // URL, which our strict CSP forbids (script-src/worker-src have no blob:/
  // data:) — so the widget could never solve and the form was dead in prod.
  // The external build instead does `new Worker(new URL(workerurl, ...))`,
  // loading a same-origin worker (public/altcha-worker.js) allowed by
  // worker-src 'self'. The external build ships its CSS separately (the
  // default inlines it), so we import altcha/altcha.css too — a same-origin
  // stylesheet, fine under style-src 'self'.
  import 'altcha/altcha.ext';
  import 'altcha/altcha.css';

  const form = document.getElementById('contribute-form') as HTMLFormElement | null;
  const anonymous = document.getElementById('cf-anonymous') as HTMLInputElement | null;
  const contributor = document.getElementById('cf-contributor') as HTMLInputElement | null;
  const out = document.getElementById('contribute-result') as HTMLElement | null;
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const guideRadio = document.getElementById('ctype-guide') as HTMLInputElement | null;
  const swRadio = document.getElementById('ctype-software') as HTMLInputElement | null;
  const guideFields = form?.querySelector<HTMLFieldSetElement>('.fields-guide');
  const swFields = form?.querySelector<HTMLFieldSetElement>('.fields-software');

  // Visibility is pure CSS (`:checked ~` rules); JS only keeps the inactive
  // fieldset `disabled` so its inputs stay out of FormData and out of native
  // constraint validation (a hidden required field would otherwise block
  // submits of the other type).
  function syncTypeState() {
    const software = !!swRadio?.checked;
    if (guideFields) guideFields.disabled = software;
    if (swFields) swFields.disabled = !software;
  }
  guideRadio?.addEventListener('change', syncTypeState);
  swRadio?.addEventListener('change', syncTypeState);

  // /contribute?type=software (the /software page's "Suggest a tool" link)
  // preselects the Software half of the toggle.
  if (swRadio && new URLSearchParams(location.search).get('type') === 'software') {
    swRadio.checked = true;
  }
  syncTypeState();

  // UX nicety mirroring the server's own semantics (functions/api/contribute.js
  // drops `contributor` whenever `anonymous` is true) — dim + disable the name
  // field instead of letting someone type a name that will silently be ignored.
  function syncContributorState() {
    if (!contributor) return;
    contributor.disabled = !!anonymous?.checked;
  }
  anonymous?.addEventListener('change', syncContributorState);
  syncContributorState();

  function showResult(message: string, ok: boolean) {
    if (!out) return;
    out.hidden = false;
    out.textContent = message;
    out.classList.toggle('result-ok', ok);
    out.classList.toggle('result-error', !ok);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;
    const fd = new FormData(form);
    const altcha = fd.get('altcha');
    if (!altcha) {
      showResult('Please complete the verification widget before submitting.', false);
      return;
    }

    const splitList = (v: FormDataEntryValue | null) =>
      String(v || '')
        .split(',')
        .map((s) => s.trim())
        .filter(Boolean);

    const shared = {
      anonymous: fd.get('anonymous') === 'on',
      contributor: fd.get('contributor'),
      website: fd.get('website'),
      altcha,
    };
    const payload =
      fd.get('ctype') === 'software'
        ? {
            type: 'software',
            name: fd.get('sw-name'),
            category: fd.get('sw-category'),
            url: fd.get('sw-url'),
            summary: fd.get('sw-summary'),
            tags: splitList(fd.get('sw-tags')),
            justification: fd.get('sw-justification'),
            sources: splitList(fd.get('sw-sources')),
            ...shared,
          }
        : {
            title: fd.get('title'),
            category: fd.get('category'),
            level: fd.get('level'),
            body: fd.get('body'),
            sources: splitList(fd.get('sources')),
            ...shared,
          };

    if (submitBtn) submitBtn.disabled = true;
    try {
      const res = await fetch('/api/contribute', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      showResult(
        res.ok
          ? 'Draft queued — it is now visible for open review at /review.'
          : 'Something went wrong — try again.',
        res.ok,
      );
      if (res.ok) {
        form.reset();
        syncContributorState();
        syncTypeState();
      }
    } catch {
      showResult('Something went wrong — try again.', false);
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

<style>
  .contribute-form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 30px;
  }
  .form-head {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 22px;
    margin-bottom: 22px;
  }
  /* honeypot: hidden from humans, left for bots that fill every field */
  .honeypot-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  /* Guide/Software toggle: visually-hidden radios + label pills; the checked
     radio drives both the pill highlight and which fieldset shows, all in
     CSS (`~` general-sibling), so the swap works before/without JS. */
  .type-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .type-toggle {
    display: inline-flex;
    gap: 6px;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 4px;
    margin-bottom: 22px;
  }
  .type-toggle label {
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    padding: 8px 14px;
    border-radius: 7px;
    cursor: pointer;
  }
  #ctype-guide:checked ~ .type-toggle label[for='ctype-guide'],
  #ctype-software:checked ~ .type-toggle label[for='ctype-software'] {
    background: var(--accent);
    color: var(--accent-ink);
  }
  /* the radios are visually hidden — surface keyboard focus on their pills */
  #ctype-guide:focus-visible ~ .type-toggle label[for='ctype-guide'],
  #ctype-software:focus-visible ~ .type-toggle label[for='ctype-software'] {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .fields-guide,
  .fields-software {
    border: 0;
    padding: 0;
    margin: 0;
    min-width: 0;
  }
  .fields-software {
    display: none;
  }
  #ctype-software:checked ~ .fields-guide {
    display: none;
  }
  #ctype-software:checked ~ .fields-software {
    display: block;
  }
  .field-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .field-hint {
    font-weight: 400;
    color: var(--muted);
  }
  .field-input {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--border);
    background: var(--surface-2);
    border-radius: 9px;
    padding: 12px 14px;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 15px;
    color: var(--ink);
    outline: none;
    margin-bottom: 22px;
  }
  .field-input:focus {
    border-color: var(--accent);
  }
  .field-mono {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13.5px;
    line-height: 1.6;
    resize: vertical;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .field-row .field-input {
    margin-bottom: 22px;
  }
  .field-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    border-top: 1px solid var(--border);
    padding-top: 18px;
  }
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 14px;
    color: var(--muted);
    cursor: pointer;
  }
  .field-contributor {
    margin-bottom: 0;
    max-width: 220px;
  }
  .field-contributor:disabled {
    opacity: 0.5;
  }
  .altcha-row {
    margin: 22px 0;
  }
  .form-submit {
    display: flex;
    justify-content: flex-end;
  }
  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: var(--accent-ink);
    border: none;
    font-family: 'IBM Plex Sans', sans-serif;
    font-weight: 600;
    font-size: 15px;
    padding: 13px 22px;
    border-radius: 9px;
    cursor: pointer;
  }
  .submit-btn:hover {
    filter: brightness(1.06);
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .result {
    margin-top: 18px;
    border-radius: 9px;
    padding: 14px 16px;
    font-size: 14.5px;
  }
  .result-ok {
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--border));
    color: var(--ink);
  }
  .result-error {
    background: color-mix(in srgb, #e5484d 12%, var(--surface));
    border: 1px solid color-mix(in srgb, #e5484d 40%, var(--border));
    color: var(--ink);
  }

  @media (max-width: 620px) {
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>
