---
// src/components/Header.astro
// Ported from design_handoff_optout_wiki/Header.dc.html — markup + inline
// styles copied verbatim from the prototype. The prototype's runtime bits
// (<x-dc>, <helmet>, support.js, sc-for/sc-if, style-hover, onClick handler)
// are prototype-only and dropped in favor of Astro's build-time templating:
//   - sc-for over navItems -> static .map() over `nav` below
//   - sc-if(item.active)   -> `current === item.key` conditional
//   - style-hover="..."    -> scoped :hover rules in <style> below
//   - theme <button>       -> <ThemeToggle /> island (Task 3)
// Nav hrefs use clean URLs (/guides, /software, /blog, /#about), not the
// prototype's *.dc.html hrefs.
import ThemeToggle from './ThemeToggle.astro';

const { current } = Astro.props;

const nav = [
  { label: 'Guides', href: '/guides', key: 'guides' },
  { label: 'Software', href: '/software', key: 'software' },
  { label: 'Blog', href: '/blog', key: 'blog' },
  { label: 'Review', href: '/review', key: 'review' },
  { label: 'About', href: '/#about', key: 'about' },
];
---
<header class="site-header">
  <a href="/" class="logo-link">
    <span>Opt</span><span class="logo-badge">Out</span>
  </a>
  <span class="tld-badge">.wiki</span>

  <nav class="site-nav">
    {nav.map((item) => (
      <a
        href={item.href}
        class="nav-link"
      >
        {item.label}
        {current === item.key && (
          <span class="nav-active-bar"></span>
        )}
      </a>
    ))}
  </nav>

  <div class="nav-spacer"></div>

  <label class="search-box">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="search-icon"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.6"/><line x1="11" y1="11" x2="14.5" y2="14.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    <input placeholder="Search opt-outs…" class="search-input"/>
    <span class="search-kbd">/</span>
  </label>

  <ThemeToggle />

  <a href="/contribute" class="contribute-link">
    Contribute
    <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M4 12L12 4M12 4H6M12 4V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 13px 28px;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(10px) saturate(1.3);
    -webkit-backdrop-filter: blur(10px) saturate(1.3);
  }
  .logo-link {
    display: flex;
    align-items: center;
    gap: 1px;
    text-decoration: none;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.025em;
    color: var(--ink);
    flex-shrink: 0;
  }
  .logo-badge {
    background: var(--ink);
    color: var(--bg);
    padding: 1px 7px 2px;
    border-radius: 2px;
  }
  .tld-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 2px 6px;
    border-radius: 3px;
    margin-left: -18px;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: 6px;
  }
  .nav-link {
    position: relative;
    display: block;
    padding: 8px 12px;
    text-decoration: none;
    font-family: 'IBM Plex Sans', sans-serif;
    font-weight: 500;
    font-size: 14.5px;
    color: var(--ink);
    border-radius: 6px;
  }
  .nav-active-bar {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: -1px;
    height: 2.5px;
    background: var(--accent);
    border-radius: 2px;
  }
  .nav-spacer {
    flex: 1;
  }
  .search-box {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 7px 11px;
    min-width: 190px;
    color: var(--muted);
  }
  .search-icon {
    flex-shrink: 0;
  }
  .search-input {
    border: none;
    outline: none;
    background: transparent;
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13.5px;
    color: var(--ink);
    width: 100%;
  }
  .search-kbd {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1px 4px;
    flex-shrink: 0;
  }
  .contribute-link {
    display: flex;
    align-items: center;
    gap: 7px;
    text-decoration: none;
    background: var(--accent);
    color: var(--accent-ink);
    font-family: 'IBM Plex Sans', sans-serif;
    font-weight: 600;
    font-size: 14px;
    padding: 9px 16px;
    border-radius: 8px;
    flex-shrink: 0;
    box-shadow: 0 1px 0 color-mix(in srgb, var(--ink) 12%, transparent);
  }

  /* Ported from the prototype's style-hover="..." runtime attribute, which
     has no HTML/CSS equivalent — expressed here as scoped :hover rules. */
  .nav-link:hover {
    background: color-mix(in srgb, var(--ink) 6%, transparent);
  }
  .contribute-link:hover {
    filter: brightness(1.05);
  }
</style>
