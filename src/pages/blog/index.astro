---
// src/pages/blog/index.astro
// The /blog index: every non-draft post, newest-first. Same query the home
// page's "latest dispatch" teaser uses (see src/pages/index.astro), just
// without the .slice(0, 3) cap. Card layout mirrors the row-style cards in
// src/pages/guides/index.astro rather than the home page's grid, since this
// is a flat chronological list rather than a curated 3-up teaser.
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { formatVerified } from '../../lib/format';

const posts = (await getCollection('blog', (p) => !p.data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);
---
<Base
  title="Blog | OptOut.wiki"
  description="Weekly notes on opting out of data collection."
>
  <Header current="blog" />
  <main class="blog-main">
    <section class="blog-head">
      <div class="eyebrow">The wiki &middot; {posts.length} post{posts.length === 1 ? '' : 's'}</div>
      <h1>Blog</h1>
      <p class="dek">Weekly notes on opting out of data collection.</p>
    </section>

    <section class="blog-body">
      <div class="post-list">
        {posts.map((p) => (
          <article class="post-card">
            <a href={`/blog/${p.id}`} class="post-card-link">
              <div class="post-card-main">
                <span class="post-card-date">{formatVerified(p.data.date)}</span>
                <h2 class="post-card-title">{p.data.title}</h2>
                <p class="post-card-summary">{p.data.summary}</p>
              </div>
              <div class="post-card-arrow" aria-hidden="true">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M3 8h10M9 4l4 4-4 4"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .blog-main {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 28px 72px;
  }
  .blog-head {
    padding: 52px 0 8px;
  }
  .eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }
  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 40px;
    letter-spacing: -0.03em;
    margin: 0 0 14px;
  }
  .dek {
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 560px;
    margin: 0;
  }
  .blog-body {
    padding-top: 24px;
  }
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .post-card {
    display: block;
  }
  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 14px;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 20px;
    transition: border-color 0.15s ease;
  }
  .post-card-link:hover {
    border-color: var(--accent);
  }
  .post-card-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11.5px;
    color: var(--muted);
    display: block;
    margin-bottom: 7px;
  }
  .post-card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 19px;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }
  .post-card-summary {
    font-size: 14px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0;
    max-width: 60ch;
  }
  .post-card-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 9px;
    border: 1px solid var(--border);
    color: var(--ink);
  }
</style>
