# script-src: no 'unsafe-inline'. The single inline script (no-flash theme in
#   Base.astro) is allow-listed by its sha256 hash; every other script is an
#   external same-origin /_astro/*.js bundle (assetsInlineLimit:0). If that
#   inline script changes, regenerate the hash — tests/csp.test.ts enforces it.
#   <script type="application/ld+json"> is data, not executed, so script-src
#   does not apply to it.
# style-src: no 'unsafe-inline'. Every component that used to carry inline
#   style="" attributes (Header, Footer, ThemeToggle, ContributeForm's/review's
#   honeypot field, software.astro's per-tool monogram color) was refactored to
#   scoped <style> classes, which Astro bundles into external same-origin CSS
#   (assetsInlineLimit:0) — covered by 'self'. tests/csp.test.ts pins this.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self'; font-src 'self'; script-src 'self' 'sha256-IcpbhC3btAGPv1dNUgFIvaoKOY1w4Wi/6wDWD9mg1Wg='; worker-src 'self'; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
